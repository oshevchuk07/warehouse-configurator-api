// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PaymentType {
  MONTHLY
  YEARLY
}

model User {
  id           Int    @id @default(autoincrement())
  email        String @unique
  passwordHash String

  firstName            String?
  lastName             String?
  isActive             Boolean   @default(false)
  avatar               String?
  passwordResetCode    String?
  passwordResetExpires DateTime?
  activationCode       String?

  role        Role        @default(USER)
  paymentType PaymentType @default(MONTHLY)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  plan   Plan? @relation(fields: [planId], references: [id])
  planId Int?
}

model Plan {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  subtitle    String?
  isActive    Boolean @default(true)
  isPopular   Boolean @default(false)

  oldMonthlyPrice Float?
  monthlyPrice    Float?
  oldYearlyPrice  Float?
  yearlyPrice     Float?

  features Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  planIntegrations PlanIntegration[]
}

// Group names (ERP, Market, etc..)
model IntegrationGroup {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  integrations Integration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integration {
  id               Int               @id @default(autoincrement())
  name             String
  url              String?
  description      String?
  logoImage        String?
  isActive         Boolean           @default(true)
  group            IntegrationGroup  @relation(fields: [groupId], references: [id])
  groupId          Int
  planIntegrations PlanIntegration[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// Store relation between Integration and plan -> many to many
model PlanIntegration {
  id            Int         @id @default(autoincrement())
  plan          Plan        @relation(fields: [planId], references: [id])
  planId        Int
  integration   Integration @relation(fields: [integrationId], references: [id])
  integrationId Int

  @@unique([planId, integrationId])
}
